# SafeRoute AI – Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit the real .env file!

# ==========================================
# Server / Backend
# ==========================================
PORT=5000
NODE_ENV=development

# MongoDB Atlas or local connection string
MONGODB_URI=mongodb://localhost:27017

# JWT Authentication
JWT_SECRET=JWT_SECRET_KEY
JWT_EXPIRE=30d

# ==========================================
# Google Maps API
# ==========================================
GOOGLE_MAPS_API_KEY=GOOGLE_MAPS_API_KEY

# ==========================================
# Twilio (SMS Notifications)
# ==========================================
TWILIO_SID=TWILIO_SID
TWILIO_AUTH_TOKEN=TWILIO_AUTH_TOKEN
TWILIO_PHONE=TWILO_PHONE_NUMBER

# ==========================================
# SendGrid (Email Notifications)
# ==========================================
SENDGRID_API_KEY=SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=EMAIL_ID

# ==========================================
# AI Microservices (Python/Flask)
# ==========================================
AI_ROUTE_SCORER_URL=http://localhost:5001
AI_VOICE_DISTRESS_URL=http://localhost:5002
